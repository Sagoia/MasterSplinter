<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:inf="using:MasterSplinter.Entrypoint.Infrastructure">

    <ResourceDictionary.ThemeDictionaries>

        <!-- ===================== LIGHT ===================== -->
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ToolAreaBrush" Color="#F3F3F3" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F7F7F7" />
            <SolidColorBrush x:Key="DividerBrush" Color="#E2E2E2" />
            <SolidColorBrush x:Key="HeaderRowBrush" Color="#EFEFEF" />
            <SolidColorBrush x:Key="MenuBarBrush" Color="#F8F8F8" />
            <SolidColorBrush x:Key="TabStripBrush" Color="#ECECEC" />
            <SolidColorBrush x:Key="TabActiveBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TabInactiveBrush" Color="#E2E2E2" />
            <SolidColorBrush x:Key="FooterBrush" Color="#E7E7EA" />

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B1B1B" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#595959" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="#8A8A8A" />
            <SolidColorBrush x:Key="LinkBrush" Color="#2563EB" />

            <SolidColorBrush x:Key="SelectionBlueBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#FFFFFF" />

            <SolidColorBrush x:Key="DiffAddedBg" Color="#E6FFEC" />
            <SolidColorBrush x:Key="DiffRemovedBg" Color="#FFECEC" />
            <SolidColorBrush x:Key="DiffHunkBg" Color="#EAF1FB" />
            <SolidColorBrush x:Key="DiffContextBg" Color="#FFFFFF" />
            <SolidColorBrush x:Key="DiffGutterBg" Color="#F6F8FA" />
            <SolidColorBrush x:Key="DiffGutterFg" Color="#9AA0A6" />
            <SolidColorBrush x:Key="DiffAddedGutterBg" Color="#CCF2D6" />
            <SolidColorBrush x:Key="DiffRemovedGutterBg" Color="#FAD4D4" />
            <SolidColorBrush x:Key="DiffTextBrush" Color="#24292F" />

            <SolidColorBrush x:Key="BadgeLocalBg" Color="#DCE9FF" />
            <SolidColorBrush x:Key="BadgeLocalFg" Color="#1F4FB8" />
            <SolidColorBrush x:Key="BadgeRemoteBg" Color="#EDE7FF" />
            <SolidColorBrush x:Key="BadgeRemoteFg" Color="#5B3FC8" />
            <SolidColorBrush x:Key="BadgeTagBg" Color="#FFF1D0" />
            <SolidColorBrush x:Key="BadgeTagFg" Color="#8A6100" />
            <SolidColorBrush x:Key="BadgeHeadBg" Color="#D9F2E2" />
            <SolidColorBrush x:Key="BadgeHeadFg" Color="#1B7A40" />
            <SolidColorBrush x:Key="BadgeBorderBrush" Color="#22000000" />
        </ResourceDictionary>

        <!-- ===================== DARK ===================== -->
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E1E1E" />
            <SolidColorBrush x:Key="ToolAreaBrush" Color="#262626" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1E1E1E" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#1F1F1F" />
            <SolidColorBrush x:Key="DividerBrush" Color="#333333" />
            <SolidColorBrush x:Key="HeaderRowBrush" Color="#2A2A2A" />
            <SolidColorBrush x:Key="MenuBarBrush" Color="#202020" />
            <SolidColorBrush x:Key="TabStripBrush" Color="#181818" />
            <SolidColorBrush x:Key="TabActiveBrush" Color="#1E1E1E" />
            <SolidColorBrush x:Key="TabInactiveBrush" Color="#2A2A2A" />
            <SolidColorBrush x:Key="FooterBrush" Color="#2D2D30" />

            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8E8E8" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B4B4B4" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="#8A8A8A" />
            <SolidColorBrush x:Key="LinkBrush" Color="#4DA3FF" />

            <SolidColorBrush x:Key="SelectionBlueBrush" Color="#2F6FEB" />
            <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#FFFFFF" />

            <SolidColorBrush x:Key="DiffAddedBg" Color="#12331F" />
            <SolidColorBrush x:Key="DiffRemovedBg" Color="#3A1D1D" />
            <SolidColorBrush x:Key="DiffHunkBg" Color="#16263F" />
            <SolidColorBrush x:Key="DiffContextBg" Color="#1E1E1E" />
            <SolidColorBrush x:Key="DiffGutterBg" Color="#181818" />
            <SolidColorBrush x:Key="DiffGutterFg" Color="#6E7681" />
            <SolidColorBrush x:Key="DiffAddedGutterBg" Color="#1B4D2B" />
            <SolidColorBrush x:Key="DiffRemovedGutterBg" Color="#5A2526" />
            <SolidColorBrush x:Key="DiffTextBrush" Color="#D6D6D6" />

            <SolidColorBrush x:Key="BadgeLocalBg" Color="#1B2C4A" />
            <SolidColorBrush x:Key="BadgeLocalFg" Color="#8FB3F2" />
            <SolidColorBrush x:Key="BadgeRemoteBg" Color="#2A2150" />
            <SolidColorBrush x:Key="BadgeRemoteFg" Color="#B79CF0" />
            <SolidColorBrush x:Key="BadgeTagBg" Color="#3A2E12" />
            <SolidColorBrush x:Key="BadgeTagFg" Color="#E3B341" />
            <SolidColorBrush x:Key="BadgeHeadBg" Color="#14331F" />
            <SolidColorBrush x:Key="BadgeHeadFg" Color="#6FCF8E" />
            <SolidColorBrush x:Key="BadgeBorderBrush" Color="#33FFFFFF" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ===================== Converters (theme-independent) ===================== -->
    <inf:BoolToVisibilityConverter x:Key="BoolToVis" />
    <inf:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True" />
    <inf:SelectedToBackgroundConverter x:Key="SelToBg" />
    <inf:SelectedToFontWeightConverter x:Key="SelToWeight" />
    <inf:ExpandedToChevronConverter x:Key="ExpToChevron" />
    <inf:LevelToMarginConverter x:Key="LevelToMargin" />
    <inf:SidebarKindToGlyphConverter x:Key="KindToGlyph" />
    <inf:SidebarKindToBranchVisibilityConverter x:Key="KindToBranchVis" />
    <inf:StatusToBrushConverter x:Key="StatusToBrush" />
    <inf:StatusToGlyphConverter x:Key="StatusToGlyph" />
    <inf:StringEqualsVisibilityConverter x:Key="StrEqVis" />

    <!-- ===================== Vector git icons (stroke = Foreground) ===================== -->
    <ControlTemplate x:Key="BranchIconTemplate" TargetType="ContentControl">
        <Viewbox Stretch="Uniform">
            <Canvas Width="24" Height="24">
                <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M7,7 L7,17 M7,12 C7,9 17,11 17,7" />
                <Ellipse Canvas.Left="4.8" Canvas.Top="4.8" Width="4.4" Height="4.4" Fill="{TemplateBinding Foreground}" />
                <Ellipse Canvas.Left="4.8" Canvas.Top="14.8" Width="4.4" Height="4.4" Fill="{TemplateBinding Foreground}" />
                <Ellipse Canvas.Left="14.8" Canvas.Top="4.8" Width="4.4" Height="4.4" Fill="{TemplateBinding Foreground}" />
            </Canvas>
        </Viewbox>
    </ControlTemplate>

    <ControlTemplate x:Key="MergeIconTemplate" TargetType="ContentControl">
        <Viewbox Stretch="Uniform">
            <Canvas Width="24" Height="24">
                <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M7,7 L7,17 M7,12 C7,15 17,13 17,17" />
                <Ellipse Canvas.Left="4.8" Canvas.Top="4.8" Width="4.4" Height="4.4" Fill="{TemplateBinding Foreground}" />
                <Ellipse Canvas.Left="4.8" Canvas.Top="14.8" Width="4.4" Height="4.4" Fill="{TemplateBinding Foreground}" />
                <Ellipse Canvas.Left="14.8" Canvas.Top="14.8" Width="4.4" Height="4.4" Fill="{TemplateBinding Foreground}" />
            </Canvas>
        </Viewbox>
    </ControlTemplate>

    <ControlTemplate x:Key="StashIconTemplate" TargetType="ContentControl">
        <Viewbox Stretch="Uniform">
            <Canvas Width="24" Height="24">
                <Path Stroke="{TemplateBinding Foreground}" StrokeThickness="2" Fill="Transparent"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="M5,13 L9,13 L10.5,15 L13.5,15 L15,13 L19,13 L19,18 L5,18 Z M12,4 L12,11 M8.5,8 L12,11.3 L15.5,8" />
            </Canvas>
        </Viewbox>
    </ControlTemplate>

    <!-- ===================== Shared styles ===================== -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Foreground" Value="{ThemeResource TextPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
    </Style>

    <Style x:Key="IconGhostButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
        <Setter Property="Padding" Value="6" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
    </Style>

    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextMutedBrush}" />
        <Setter Property="CharacterSpacing" Value="60" />
    </Style>

</ResourceDictionary>
