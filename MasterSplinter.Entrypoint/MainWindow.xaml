<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MasterSplinter.Entrypoint.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MasterSplinter.Entrypoint"
    xmlns:ctl="using:MasterSplinter.Entrypoint.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MasterSplinter — Git Client">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- custom title bar (menu lives here, kept at 100% so caption buttons align) -->
            <RowDefinition Height="*" />
            <!-- zoom host: tab strip + workspace, scaled down -->
        </Grid.RowDefinitions>

        <!-- ===================== CUSTOM TITLE BAR ===================== -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Background="{ThemeResource MenuBarBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPaddingColumn" Width="0" />
                <ColumnDefinition Width="Auto" />
                <!-- app icon + title -->
                <ColumnDefinition Width="Auto" />
                <!-- menu bar -->
                <ColumnDefinition Width="*" />
                <!-- draggable region -->
                <ColumnDefinition x:Name="RightPaddingColumn" Width="0" />
                <!-- reserved for caption buttons -->
            </Grid.ColumnDefinitions>

            <!-- bottom divider (spans all columns, click-through) -->
            <Border Grid.Column="0" Grid.ColumnSpan="5" BorderBrush="{ThemeResource DividerBrush}"
                    BorderThickness="0,0,0,1" IsHitTestVisible="False" />

            <!-- app icon + title -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center" Margin="14,0,10,0">
                <ContentControl Template="{StaticResource BranchIconTemplate}" Width="18" Height="18"
                                Foreground="{ThemeResource LinkBrush}" IsTabStop="False" VerticalAlignment="Center" />
                <TextBlock Text="MasterSplinter" FontSize="13" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock x:Name="CoreInfo" FontSize="11" VerticalAlignment="Center" Margin="2,1,0,0"
                           Foreground="{ThemeResource TextMutedBrush}" />
            </StackPanel>

            <!-- top menu -->
            <MenuBar Grid.Column="2" Background="Transparent" VerticalAlignment="Center">
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Text="Open Repository…" Click="OpenRepository_Click" />
                    <MenuFlyoutItem Text="Clone / New…" IsEnabled="False" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Exit" Click="Exit_Click" />
                </MenuBarItem>
                <MenuBarItem Title="Edit">
                    <MenuFlyoutItem Text="Undo" />
                    <MenuFlyoutItem Text="Redo" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Copy" />
                    <MenuFlyoutItem Text="Paste" />
                    <MenuFlyoutItem Text="Select All" />
                </MenuBarItem>
                <MenuBarItem Title="View">
                    <MenuFlyoutItem Text="Toggle Light / Dark Theme" Click="ToggleTheme_Click" />
                    <MenuFlyoutItem Text="Refresh" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Show Sidebar" />
                    <MenuFlyoutItem Text="Show Diff Panel" />
                </MenuBarItem>
                <MenuBarItem Title="Repository">
                    <MenuFlyoutItem Text="Repository Settings…" />
                    <MenuFlyoutItem Text="Add Remote…" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Git Flow…" />
                </MenuBarItem>
                <MenuBarItem Title="Actions">
                    <MenuFlyoutItem Text="Commit…" />
                    <MenuFlyoutItem Text="Push…" />
                    <MenuFlyoutItem Text="Pull…" />
                    <MenuFlyoutItem Text="Fetch…" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Branch…" />
                    <MenuFlyoutItem Text="Merge…" />
                    <MenuFlyoutItem Text="Stash" />
                </MenuBarItem>
                <MenuBarItem Title="Tools">
                    <MenuFlyoutItem Text="Options…" />
                    <MenuFlyoutItem Text="Open in Terminal" />
                    <MenuFlyoutItem Text="Open in Explorer" />
                </MenuBarItem>
                <MenuBarItem Title="Help">
                    <MenuFlyoutItem Text="Documentation" />
                    <MenuFlyoutItem Text="About MasterSplinter" />
                </MenuBarItem>
            </MenuBar>

            <!-- draggable caption region -->
            <Border x:Name="TitleBarDrag" Grid.Column="3" Background="Transparent" />
        </Grid>

        <!-- ===================== ZOOM HOST (scales tab strip + workspace) ===================== -->
        <!-- A RenderTransform scales the content; ScaledRoot is sized to host/scale in code-behind
             so the scaled content still fills the available area. -->
        <Grid x:Name="ZoomHost" Grid.Row="1" SizeChanged="ZoomHost_SizeChanged">
            <Grid x:Name="ScaledRoot" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="UiScale" ScaleX="1" ScaleY="1" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- repository tab strip -->
                    <RowDefinition Height="*" />
                    <!-- workspace for the active repository -->
                </Grid.RowDefinitions>

        <!-- ===================== REPOSITORY TAB STRIP ===================== -->
        <!-- TabView is used as a strip only; the workspace lives in its own row below so that
             it gets a bounded height and fills correctly (TabView's content host sizes to content). -->
        <!-- One tab per opened repository; the shared workspace below renders the active one. -->
        <TabView Grid.Row="0" x:Name="RepoTabs"
                 TabWidthMode="SizeToContent"
                 AddTabButtonClick="RepoTabs_AddTabButtonClick"
                 SelectionChanged="RepoTabs_SelectionChanged"
                 TabCloseRequested="RepoTabs_TabCloseRequested" />

                <!-- ===================== ACTIVE REPOSITORY WORKSPACE ===================== -->
                <ctl:RepositoryWorkspace Grid.Row="1" x:Name="Workspace" />
            </Grid>
        </Grid>
    </Grid>
</Window>
