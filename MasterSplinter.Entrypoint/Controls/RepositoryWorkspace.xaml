<UserControl
    x:Class="MasterSplinter.Entrypoint.Controls.RepositoryWorkspace"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:inf="using:MasterSplinter.Entrypoint.Infrastructure"
    xmlns:ctl="using:MasterSplinter.Entrypoint.Controls"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>

        <!-- ===== Badge templates ===== -->
        <DataTemplate x:Key="BadgeLocalTemplate">
            <Border Background="{ThemeResource BadgeLocalBg}" BorderBrush="{ThemeResource BadgeBorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="5,0" Margin="0,0,5,0" Height="18" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <ContentControl Template="{StaticResource BranchIconTemplate}" Width="11" Height="11" IsTabStop="False"
                                    Foreground="{ThemeResource BadgeLocalFg}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{ThemeResource BadgeLocalFg}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="BadgeRemoteTemplate">
            <Border Background="{ThemeResource BadgeRemoteBg}" BorderBrush="{ThemeResource BadgeBorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="5,0" Margin="0,0,5,0" Height="18" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <ContentControl Template="{StaticResource BranchIconTemplate}" Width="11" Height="11" IsTabStop="False"
                                    Foreground="{ThemeResource BadgeRemoteFg}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{ThemeResource BadgeRemoteFg}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="BadgeTagTemplate">
            <Border Background="{ThemeResource BadgeTagBg}" BorderBrush="{ThemeResource BadgeBorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="5,0" Margin="0,0,5,0" Height="18" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8EC;" FontSize="10"
                              Foreground="{ThemeResource BadgeTagFg}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{ThemeResource BadgeTagFg}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="BadgeHeadTemplate">
            <Border Background="{ThemeResource BadgeHeadBg}" BorderBrush="{ThemeResource BadgeBorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="5,0" Margin="0,0,5,0" Height="18" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <ContentControl Template="{StaticResource BranchIconTemplate}" Width="11" Height="11" IsTabStop="False"
                                    Foreground="{ThemeResource BadgeHeadFg}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{ThemeResource BadgeHeadFg}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <inf:BadgeTemplateSelector x:Key="BadgeSelector"
            LocalBranch="{StaticResource BadgeLocalTemplate}"
            RemoteBranch="{StaticResource BadgeRemoteTemplate}"
            Tag="{StaticResource BadgeTagTemplate}"
            Head="{StaticResource BadgeHeadTemplate}" />

        <!-- ===== Diff line templates ===== -->
        <DataTemplate x:Key="DiffContextTemplate">
            <Border Background="{ThemeResource DiffContextBg}">
                <Grid ColumnDefinitions="46,46,16,*" MinHeight="18">
                    <Border Background="{ThemeResource DiffGutterBg}">
                        <TextBlock Text="{Binding OldNo}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Background="{ThemeResource DiffGutterBg}">
                        <TextBlock Text="{Binding NewNo}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="3" inf:Syntax.Code="{Binding Text}" inf:Syntax.Lang="{Binding LanguageId}"
                               FontFamily="Consolas" FontSize="12.5" TextWrapping="NoWrap"
                               Foreground="{ThemeResource DiffTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DiffAddedTemplate">
            <Border Background="{ThemeResource DiffAddedBg}">
                <Grid ColumnDefinitions="46,46,16,*" MinHeight="18">
                    <Border Background="{ThemeResource DiffAddedGutterBg}">
                        <TextBlock Text="{Binding OldNo}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Background="{ThemeResource DiffAddedGutterBg}">
                        <TextBlock Text="{Binding NewNo}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="2" Text="+" FontFamily="Consolas" FontSize="12.5" Foreground="#2DA44E"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" inf:Syntax.Code="{Binding Text}" inf:Syntax.Lang="{Binding LanguageId}"
                               FontFamily="Consolas" FontSize="12.5" TextWrapping="NoWrap"
                               Foreground="{ThemeResource DiffTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DiffRemovedTemplate">
            <Border Background="{ThemeResource DiffRemovedBg}">
                <Grid ColumnDefinitions="46,46,16,*" MinHeight="18">
                    <Border Background="{ThemeResource DiffRemovedGutterBg}">
                        <TextBlock Text="{Binding OldNo}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <Border Grid.Column="1" Background="{ThemeResource DiffRemovedGutterBg}">
                        <TextBlock Text="{Binding NewNo}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="2" Text="&#x2212;" FontFamily="Consolas" FontSize="12.5" Foreground="#CF222E"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" inf:Syntax.Code="{Binding Text}" inf:Syntax.Lang="{Binding LanguageId}"
                               FontFamily="Consolas" FontSize="12.5" TextWrapping="NoWrap"
                               Foreground="{ThemeResource DiffTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DiffHunkTemplate">
            <Border Background="{ThemeResource DiffHunkBg}" BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,1,0,1">
                <Grid ColumnDefinitions="*,Auto" MinHeight="22">
                    <TextBlock Text="{Binding Text}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource LinkBrush}"
                               Margin="10,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Margin="0,1,8,1" Padding="8,2"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7A7;" FontSize="11"
                                      Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text="Reverse hunk" FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

        <inf:DiffLineTemplateSelector x:Key="DiffSelector"
            Context="{StaticResource DiffContextTemplate}"
            Added="{StaticResource DiffAddedTemplate}"
            Removed="{StaticResource DiffRemovedTemplate}"
            Hunk="{StaticResource DiffHunkTemplate}" />

        <!-- ===== Side-by-side diff cell templates (DIFF-002) ===== -->
        <DataTemplate x:Key="DiffCellEmpty">
            <Border Background="{ThemeResource DiffGutterBg}" MinHeight="18" />
        </DataTemplate>

        <DataTemplate x:Key="DiffCellContext">
            <Border Background="{ThemeResource DiffContextBg}">
                <Grid ColumnDefinitions="46,*" MinHeight="18">
                    <Border Background="{ThemeResource DiffGutterBg}">
                        <TextBlock Text="{Binding No}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1" inf:Syntax.Code="{Binding Text}" inf:Syntax.Lang="{Binding LanguageId}"
                               FontFamily="Consolas" FontSize="12.5" TextWrapping="NoWrap"
                               Foreground="{ThemeResource DiffTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DiffCellRemoved">
            <Border Background="{ThemeResource DiffRemovedBg}">
                <Grid ColumnDefinitions="46,*" MinHeight="18">
                    <Border Background="{ThemeResource DiffRemovedGutterBg}">
                        <TextBlock Text="{Binding No}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1" inf:Syntax.Code="{Binding Text}" inf:Syntax.Lang="{Binding LanguageId}"
                               FontFamily="Consolas" FontSize="12.5" TextWrapping="NoWrap"
                               Foreground="{ThemeResource DiffTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DiffCellAdded">
            <Border Background="{ThemeResource DiffAddedBg}">
                <Grid ColumnDefinitions="46,*" MinHeight="18">
                    <Border Background="{ThemeResource DiffAddedGutterBg}">
                        <TextBlock Text="{Binding No}" FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource DiffGutterFg}"
                                   HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1" inf:Syntax.Code="{Binding Text}" inf:Syntax.Lang="{Binding LanguageId}"
                               FontFamily="Consolas" FontSize="12.5" TextWrapping="NoWrap"
                               Foreground="{ThemeResource DiffTextBrush}" Margin="6,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <inf:DiffCellTemplateSelector x:Key="DiffCellSelector"
            Empty="{StaticResource DiffCellEmpty}"
            Context="{StaticResource DiffCellContext}"
            Added="{StaticResource DiffCellAdded}"
            Removed="{StaticResource DiffCellRemoved}" />

        <DataTemplate x:Key="SbsSplitTemplate">
            <Grid ColumnDefinitions="*,1,*">
                <ContentControl Content="{Binding Left}" ContentTemplateSelector="{StaticResource DiffCellSelector}"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" IsTabStop="False" />
                <Border Grid.Column="1" Background="{ThemeResource DividerBrush}" />
                <ContentControl Grid.Column="2" Content="{Binding Right}" ContentTemplateSelector="{StaticResource DiffCellSelector}"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" IsTabStop="False" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SbsHunkTemplate">
            <Border Background="{ThemeResource DiffHunkBg}" BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,1,0,1">
                <TextBlock Text="{Binding HunkText}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource LinkBrush}"
                           Margin="10,2" TextTrimming="CharacterEllipsis" />
            </Border>
        </DataTemplate>

        <inf:DiffRowTemplateSelector x:Key="SbsRowSelector"
            Hunk="{StaticResource SbsHunkTemplate}"
            Split="{StaticResource SbsSplitTemplate}" />

        <!-- ===== Sidebar templates ===== -->
        <DataTemplate x:Key="SidebarHeaderTemplate">
            <Border Background="Transparent" Height="30" Padding="8,0,0,0"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="10"
                              Glyph="{Binding IsExpanded, Converter={StaticResource ExpToChevron}}"
                              Foreground="{ThemeResource TextMutedBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Text}" Style="{StaticResource SectionHeaderTextStyle}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SidebarLeafTemplate">
            <Border Height="26" Margin="4,0" CornerRadius="4"
                    Background="{Binding IsSelected, Converter={StaticResource SelToBg}}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
                <Grid Margin="{Binding Level, Converter={StaticResource LevelToMargin}}"
                      ColumnDefinitions="14,18,*" VerticalAlignment="Center">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="9"
                              Glyph="{Binding IsExpanded, Converter={StaticResource ExpToChevron}}"
                              Foreground="{ThemeResource TextMutedBrush}" VerticalAlignment="Center"
                              Visibility="{Binding IsExpandable, Converter={StaticResource BoolToVis}}" />
                    <Grid Grid.Column="1" Width="16" Height="16" VerticalAlignment="Center">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="13"
                                  Glyph="{Binding Kind, Converter={StaticResource KindToGlyph}}"
                                  Foreground="{ThemeResource TextSecondaryBrush}" />
                        <ContentControl Template="{StaticResource BranchIconTemplate}" Width="13" Height="13" IsTabStop="False"
                                        Foreground="{ThemeResource TextSecondaryBrush}"
                                        Visibility="{Binding Kind, Converter={StaticResource KindToBranchVis}}" />
                    </Grid>
                    <TextBlock Grid.Column="2" Margin="6,0,0,0" Text="{Binding Text}" VerticalAlignment="Center" FontSize="13"
                               FontWeight="{Binding IsSelected, Converter={StaticResource SelToWeight}}"
                               Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </DataTemplate>

        <inf:SidebarTemplateSelector x:Key="SidebarSelector"
            Header="{StaticResource SidebarHeaderTemplate}"
            Leaf="{StaticResource SidebarLeafTemplate}" />

        <!-- ===== ListView item container styles ===== -->
        <Style x:Key="CommitItemStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="FileItemStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="DiffItemStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        </Style>

        <!-- Grouped working-copy status list (STATUS-002). Source is set in code-behind
             (Vm.StatusGroups) because the DataContext is not available to resources. -->
        <CollectionViewSource x:Name="StatusGroupsView" IsSourceGrouped="True" />

    </UserControl.Resources>

    <!-- ============================================================ LAYOUT -->
    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <!-- Refresh accelerators live here as well as on the View ▸ Refresh menu item, because
             MenuFlyoutItem accelerators are unreliable in WinUI 3 while the flyout is closed. -->
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="F5" Invoked="RefreshAccelerator_Invoked" />
            <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="RefreshAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- error bar -->
            <RowDefinition Height="Auto" />
            <!-- command toolbar -->
            <RowDefinition Height="*" />
            <!-- main content (history + detail/diff + mode tabs) -->
        </Grid.RowDefinitions>

        <!-- ===================== ERROR BAR (CORE-001) ===================== -->
        <InfoBar Grid.Row="0" Severity="Error" IsOpen="{Binding HasError, Mode=OneWay}"
                 Title="Could not open repository" Message="{Binding ErrorMessage}"
                 CloseButtonClick="ErrorBar_CloseClick" />

        <!-- ===================== COMMAND TOOLBAR ===================== -->
        <Border Grid.Row="1" Background="{ThemeResource ToolAreaBrush}" BorderBrush="{ThemeResource DividerBrush}"
                BorderThickness="0,0,0,1">
            <Grid Padding="6,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ctl:ToolButton Glyph="&#xE73E;" Label="Commit" />
                    <ctl:ToolButton Glyph="&#xE898;" Label="Push" />
                    <ctl:ToolButton Glyph="&#xE896;" Label="Pull" />
                    <ctl:ToolButton Glyph="&#xE895;" Label="Fetch" />
                    <Rectangle Width="1" Height="38" Fill="{ThemeResource DividerBrush}" Margin="6,0" />
                    <ctl:ToolButton Vector="branch" Label="Branch" />
                    <ctl:ToolButton Vector="merge" Label="Merge" IsEnabled="False" />
                    <ctl:ToolButton Vector="stash" Label="Stash" />
                    <ctl:ToolButton Glyph="&#xE7A7;" Label="Discard" IsEnabled="False" />
                    <ctl:ToolButton Glyph="&#xE8EC;" Label="Tag" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Rectangle Width="1" Height="38" Fill="{ThemeResource DividerBrush}" Margin="6,0" />
                    <ctl:ToolButton x:Name="RefreshBtn" Glyph="&#xE72C;" Label="Refresh" Click="Refresh_Click" />
                    <ctl:ToolButton Glyph="&#xE7C1;" Label="Git Flow" />
                    <ctl:ToolButton Glyph="&#xE756;" Label="Terminal" />
                    <ctl:ToolButton Glyph="&#xE8B7;" Label="Explorer" />
                    <ctl:ToolButton x:Name="CompareBtn" Glyph="&#xE8AB;" Label="Compare" Click="CompareRefs_Click" />
                    <ctl:ToolButton Glyph="&#xE713;" Label="Settings" />
                    <ctl:ToolButton x:Name="ThemeBtn" Glyph="&#xE706;" Label="Theme" Click="ThemeBtn_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== MAIN CONTENT (sidebar | right) ===================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="460" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left navigation sidebar -->
            <Border Grid.Column="0" Background="{ThemeResource SidebarBackgroundBrush}"
                    BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,6">
                    <ItemsControl x:Name="SidebarHost" ItemsSource="{Binding Sidebar}"
                                  ItemTemplateSelector="{StaticResource SidebarSelector}" Tapped="SidebarHost_Tapped" />
                </ScrollViewer>
            </Border>

            <ctk:GridSplitter Grid.Column="1" Orientation="Vertical"
                              ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />

            <!-- Right side: filter + history (top) / detail + diff (bottom) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- filter row -->
                    <RowDefinition Height="*" MinHeight="120" />
                    <!-- commit history -->
                    <RowDefinition Height="12" />
                    <!-- horizontal splitter -->
                    <RowDefinition Height="300" MinHeight="160" MaxHeight="640" />
                    <!-- detail + diff -->
                </Grid.RowDefinitions>

                <!-- Filter row -->
                <Border Grid.Row="0" Background="{ThemeResource ToolAreaBrush}" BorderBrush="{ThemeResource DividerBrush}"
                        BorderThickness="0,0,0,1" Padding="8,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Repository header (CORE-003): name + current branch chip -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8B7;" FontSize="14"
                                      Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Repository.Name}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <Border Background="{ThemeResource BadgeLocalBg}" BorderBrush="{ThemeResource BadgeBorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="6,1" Height="20" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <ContentControl Template="{StaticResource BranchIconTemplate}" Width="11" Height="11"
                                                    IsTabStop="False" Foreground="{ThemeResource BadgeLocalFg}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Repository.Branch}" FontSize="11"
                                               Foreground="{ThemeResource BadgeLocalFg}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Rectangle Width="1" Height="20" Fill="{ThemeResource DividerBrush}" Margin="4,0" />
                            <TextBlock Text="Order:" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="12" />
                            <ComboBox ItemsSource="{Binding OrderOptions}" SelectedIndex="{Binding SelectedOrderIndex, Mode=TwoWay}"
                                      MinWidth="150" Height="30" />
                            <ProgressRing IsActive="{Binding IsLoading}" Width="16" Height="16" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Search:" Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="12" />
                            <TextBox PlaceholderText="message, author or SHA" Width="220" Height="30"
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Commit history (header + table) -->
                <Grid Grid.Row="1" Background="{ThemeResource PanelBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- column header -->
                    <Border Grid.Row="0" Background="{ThemeResource HeaderRowBrush}" BorderBrush="{ThemeResource DividerBrush}"
                            BorderThickness="0,0,0,1" Height="28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Graph" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="1" Text="Description" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="2" Text="Date" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="3" Text="Author" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Grid.Column="4" Text="Commit" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextSecondaryBrush}" />
                        </Grid>
                    </Border>

                    <!-- commit rows -->
                    <ListView x:Name="CommitsList" Grid.Row="1" ItemsSource="{Binding Commits}"
                              SelectedItem="{Binding SelectedCommit, Mode=OneWay}"
                              SelectionChanged="Commits_SelectionChanged"
                              SelectionMode="Single" Padding="0"
                              ItemContainerStyle="{StaticResource CommitItemStyle}"
                              ScrollViewer.HorizontalScrollMode="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.Resources>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#2563EB" />
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#1D5FD8" />
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#1A55C4" />
                            <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="#FFFFFF" />
                        </ListView.Resources>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ContextFlyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Copy SHA" Click="CopyShortHash_Click" />
                                            <MenuFlyoutItem Text="Copy Full SHA" Click="CopyFullHash_Click" />
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="Mark for Comparison" Click="MarkForComparison_Click" />
                                            <MenuFlyoutItem Text="Compare with Marked Commit" Click="CompareWithMarked_Click" />
                                        </MenuFlyout>
                                    </Grid.ContextFlyout>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>

                                    <inf:GraphCanvas Row="{Binding Graph}" VerticalAlignment="Center" Margin="2,0,0,0" />

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="2">
                                        <ItemsControl ItemsSource="{Binding Badges}" ItemTemplateSelector="{StaticResource BadgeSelector}"
                                                      VerticalAlignment="Center">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <TextBlock Text="{Binding Message}" VerticalAlignment="Center" FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding Date}" VerticalAlignment="Center" FontSize="12"
                                               Opacity="0.75" />
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="5" Opacity="0.85">
                                        <TextBlock Text="{Binding Author}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding AuthorEmail}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="4" Text="{Binding Hash}" VerticalAlignment="Center" FontSize="12"
                                               FontFamily="Consolas" Opacity="0.8" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- horizontal splitter between history and detail -->
                <ctk:GridSplitter Grid.Row="2" Orientation="Horizontal"
                                  ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" />

                <!-- bottom: commit detail | diff -->
                <Grid Grid.Row="3" Background="{ThemeResource PanelBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="460" MinWidth="300" MaxWidth="800" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- commit detail panel -->
                    <Border Grid.Column="0" BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <!-- bottom mode tabs (inside the changed-files panel) -->
                            </Grid.RowDefinitions>

                            <!-- compare banner (DIFF-006/007) -->
                            <Border Grid.Row="0" Background="{ThemeResource BadgeLocalBg}" BorderBrush="{ThemeResource DividerBrush}"
                                    BorderThickness="0,0,0,1" Padding="12,8"
                                    Visibility="{Binding IsCompareMode, Converter={StaticResource BoolToVis}}">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8AB;" FontSize="14"
                                              Foreground="{ThemeResource BadgeLocalFg}" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Comparing" FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding CompareTitle}" FontFamily="Consolas" FontSize="12.5"
                                                   Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Exit" Click="ExitCompare_Click"
                                            Style="{StaticResource GhostButtonStyle}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- metadata -->
                            <Grid Grid.Row="0" Padding="12,10,12,6" ColumnSpacing="10" RowSpacing="3"
                                  Visibility="{Binding ShowCommitPane, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Commit:" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Grid.Column="1" Text="{Binding SelectedCommit.FullHash}" Foreground="{ThemeResource LinkBrush}"
                                           FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True" TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Row="1" Text="Parents:" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedCommit.Parents}" Foreground="{ThemeResource LinkBrush}"
                                           FontFamily="Consolas" FontSize="12" TextTrimming="CharacterEllipsis" />

                                <TextBlock Grid.Row="2" Text="Author:" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding SelectedCommit.Author}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding SelectedCommit.AuthorEmail}" Foreground="{ThemeResource TextMutedBrush}" FontSize="12" />
                                </StackPanel>

                                <TextBlock Grid.Row="3" Text="Date:" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedCommit.Date}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12" />

                                <TextBlock Grid.Row="4" Text="Committer:" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedCommit.Committer}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12" />

                                <!-- diff summary (DIFF-001) -->
                                <TextBlock Grid.Row="5" Text="Changes:" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ChangedSummary}" Foreground="{ThemeResource TextPrimaryBrush}"
                                           FontSize="12" TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <!-- full commit message -->
                            <Border Grid.Row="1" Margin="12,2,12,8" Padding="10,8" CornerRadius="4"
                                    Background="{ThemeResource ToolAreaBrush}" BorderBrush="{ThemeResource DividerBrush}" BorderThickness="1"
                                    Visibility="{Binding ShowCommitPane, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding SelectedCommit.FullMessage}" TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True"
                                           Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13" />
                            </Border>

                            <!-- changed files header -->
                            <Border Grid.Row="2" Background="{ThemeResource HeaderRowBrush}" BorderBrush="{ThemeResource DividerBrush}"
                                    BorderThickness="0,1,0,1" Height="26" Padding="12,0">
                                <Grid>
                                    <TextBlock Text="CHANGED FILES" Style="{StaticResource SectionHeaderTextStyle}" VerticalAlignment="Center"
                                               Visibility="{Binding IsWorkingCopyMode, Converter={StaticResource InvBoolToVis}}" />
                                    <Grid Visibility="{Binding IsWorkingCopyMode, Converter={StaticResource BoolToVis}}"
                                          ColumnDefinitions="Auto,*">
                                        <TextBlock Text="WORKING COPY" Style="{StaticResource SectionHeaderTextStyle}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding ChangedSummary}" FontSize="11" Margin="10,0,0,0"
                                                   Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- working-copy status list (STATUS-001/002), grouped by section -->
                            <ListView Grid.Row="3" x:Name="WorkingFilesList"
                                      ItemsSource="{Binding Source={StaticResource StatusGroupsView}}"
                                      SelectedItem="{Binding SelectedFile, Mode=OneWay}"
                                      SelectionChanged="Files_SelectionChanged"
                                      SelectionMode="Single" Padding="0"
                                      ItemContainerStyle="{StaticResource FileItemStyle}"
                                      Visibility="{Binding IsWorkingCopyMode, Converter={StaticResource BoolToVis}}">
                                <ListView.Resources>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#2563EB" />
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#1D5FD8" />
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#1A55C4" />
                                    <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="#FFFFFF" />
                                </ListView.Resources>
                                <ListView.GroupStyle>
                                    <GroupStyle HidesIfEmpty="True">
                                        <GroupStyle.HeaderContainerStyle>
                                            <Style TargetType="ListViewHeaderItem">
                                                <Setter Property="MinHeight" Value="26" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </GroupStyle.HeaderContainerStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Background="{ThemeResource HeaderRowBrush}" Height="24" Padding="12,0">
                                                    <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListView.GroupStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="12,0" ColumnDefinitions="18,*" DoubleTapped="WorkingFile_DoubleTapped">
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Open in External Editor" Click="OpenInEditor_Click" />
                                                    <MenuFlyoutItem Text="Reveal in Explorer" Click="RevealInExplorer_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Copy Path" Click="CopyFilePath_Click" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12"
                                                      Glyph="{Binding Status, Converter={StaticResource StatusToGlyph}}"
                                                      Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding DisplayPath}" FontSize="12.5"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- changed files list -->
                            <ListView Grid.Row="3" x:Name="FilesList" ItemsSource="{Binding PanelFiles}"
                                      SelectedItem="{Binding SelectedFile, Mode=OneWay}"
                                      SelectionChanged="Files_SelectionChanged"
                                      SelectionMode="Single" Padding="0"
                                      ItemContainerStyle="{StaticResource FileItemStyle}"
                                      Visibility="{Binding IsWorkingCopyMode, Converter={StaticResource InvBoolToVis}}">
                                <ListView.Resources>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="#2563EB" />
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="#1D5FD8" />
                                    <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="#1A55C4" />
                                    <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="#FFFFFF" />
                                </ListView.Resources>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="12,0" ColumnDefinitions="18,*" DoubleTapped="File_DoubleTapped">
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Open File at This Commit" Click="OpenFileAtCommit_Click" />
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12"
                                                      Glyph="{Binding Status, Converter={StaticResource StatusToGlyph}}"
                                                      Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding Path}" FontSize="12.5"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- ===== BOTTOM MODE TABS (SelectorBar, docked at the bottom of the changed-files panel) ===== -->
                            <Border Grid.Row="4" Background="{ThemeResource FooterBrush}"
                                    BorderBrush="{ThemeResource DividerBrush}" BorderThickness="0,1,0,0" Padding="6,2">
                                <SelectorBar x:Name="ModeBar" VerticalAlignment="Center"
                                             SelectionChanged="ModeBar_SelectionChanged">
                                    <SelectorBarItem x:Name="ModeFileStatus" Text="File Status" />
                                    <SelectorBarItem x:Name="ModeLogHistory" Text="Log / History" IsSelected="True" />
                                    <SelectorBarItem Text="Search" />
                                </SelectorBar>
                            </Border>
                        </Grid>
                    </Border>

                    <ctk:GridSplitter Grid.Column="1" Orientation="Vertical"
                                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext" />

                    <!-- diff viewer -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- diff header -->
                        <Border Grid.Row="0" Background="{ThemeResource ToolAreaBrush}" BorderBrush="{ThemeResource DividerBrush}"
                                BorderThickness="0,0,0,1" Padding="10,5">
                            <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedFile.Path}" FontFamily="Consolas" FontSize="12.5"
                                           Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <!-- DIFF-002: unified vs side-by-side -->
                                <ToggleSwitch Grid.Column="1" MinWidth="0" Margin="8,0,4,0" VerticalAlignment="Center"
                                              OffContent="Unified" OnContent="Side by side"
                                              IsOn="{Binding IsSideBySide, Mode=TwoWay}" />
                                <!-- DIFF-003/004: syntax + whitespace options. The flyout is opened
                                     explicitly from the Click handler (Button.Flyout did not trigger
                                     reliably on this styled icon button). -->
                                <Button Grid.Column="2" Style="{StaticResource IconGhostButtonStyle}" Margin="2,0"
                                        ToolTipService.ToolTip="Diff settings" Click="DiffSettings_Click">
                                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE713;" FontSize="15"
                                              Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <FlyoutBase.AttachedFlyout>
                                        <Flyout>
                                            <StackPanel Spacing="12" MinWidth="220">
                                                <ToggleSwitch Header="Syntax highlighting" OnContent="On" OffContent="Off"
                                                              IsOn="{Binding SyntaxHighlightOn, Mode=TwoWay}" />
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="Whitespace" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" />
                                                    <ComboBox HorizontalAlignment="Stretch" SelectedIndex="{Binding WhitespaceIndex, Mode=TwoWay}">
                                                        <ComboBoxItem Content="Show all changes" />
                                                        <ComboBoxItem Content="Ignore space changes" />
                                                        <ComboBoxItem Content="Ignore all whitespace" />
                                                    </ComboBox>
                                                </StackPanel>
                                            </StackPanel>
                                        </Flyout>
                                    </FlyoutBase.AttachedFlyout>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- diff body: unified / side-by-side / binary, switched by the view-model -->
                        <Grid Grid.Row="1">
                            <!-- unified (DIFF-002) -->
                            <ListView ItemsSource="{Binding SelectedFile.Diff}" SelectionMode="None"
                                      Visibility="{Binding ShowUnified, Converter={StaticResource BoolToVis}}"
                                      IsItemClickEnabled="False" Padding="0"
                                      ItemTemplateSelector="{StaticResource DiffSelector}"
                                      ItemContainerStyle="{StaticResource DiffItemStyle}"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.Resources>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                                    <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent" />
                                </ListView.Resources>
                            </ListView>

                            <!-- side-by-side (DIFF-002) -->
                            <ListView ItemsSource="{Binding SelectedFile.Rows}" SelectionMode="None"
                                      Visibility="{Binding ShowSideBySide, Converter={StaticResource BoolToVis}}"
                                      IsItemClickEnabled="False" Padding="0"
                                      ItemTemplateSelector="{StaticResource SbsRowSelector}"
                                      ItemContainerStyle="{StaticResource DiffItemStyle}"
                                      ScrollViewer.HorizontalScrollMode="Disabled"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.Resources>
                                    <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent" />
                                    <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent" />
                                </ListView.Resources>
                            </ListView>

                            <!-- binary / image placeholder (DIFF-005) -->
                            <ScrollViewer Visibility="{Binding ShowBinary, Converter={StaticResource BoolToVis}}"
                                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                <StackPanel Spacing="14" Margin="16" HorizontalAlignment="Center">
                                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8A5;" FontSize="32"
                                              Foreground="{ThemeResource TextMutedBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding BinaryInfoText}" Foreground="{ThemeResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16"
                                          Visibility="{Binding BinaryHasImages, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Before" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                                       HorizontalAlignment="Center" />
                                            <Border BorderBrush="{ThemeResource DividerBrush}" BorderThickness="1" Padding="4">
                                                <Image Source="{Binding BinaryOldImage}" Stretch="Uniform" MaxHeight="320" />
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock Text="After" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                                       HorizontalAlignment="Center" />
                                            <Border BorderBrush="{ThemeResource DividerBrush}" BorderThickness="1" Padding="4">
                                                <Image Source="{Binding BinaryNewImage}" Stretch="Uniform" MaxHeight="320" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===================== HOME / EMPTY STATE (CORE-002) ===================== -->
        <Grid Grid.Row="2" Background="{ThemeResource AppBackgroundBrush}"
              Visibility="{Binding HasRepository, Converter={StaticResource InvBoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="480" Spacing="12">
                <ContentControl Template="{StaticResource BranchIconTemplate}" Width="44" Height="44"
                                Foreground="{ThemeResource LinkBrush}" IsTabStop="False" HorizontalAlignment="Center" />
                <TextBlock Text="Open a repository" FontSize="22" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Choose a folder that contains a Git repository to browse its history."
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13" TextAlignment="Center"
                           TextWrapping="Wrap" HorizontalAlignment="Center" />
                <Button Content="Open Repository…" Click="OpenRepo_Click" HorizontalAlignment="Center"
                        Style="{StaticResource AccentButtonStyle}" Padding="16,6" Margin="0,4,0,2" />

                <TextBlock Text="RECENT REPOSITORIES" Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="2,12,0,0" HorizontalAlignment="Left" />
                <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Recent}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Style="{StaticResource GhostButtonStyle}" Margin="0,2"
                                        Tag="{Binding Path}" Click="RecentItem_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8B7;" FontSize="14"
                                                  Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{ThemeResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding Path}" FontSize="11" Foreground="{ThemeResource TextMutedBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
